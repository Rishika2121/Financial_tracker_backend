# ========== SERVER CONFIGURATION ==========
PORT=5000
NODE_ENV=production

# ========== GROQ API (for AI Chat) ==========
GROQ_API_KEY=your_groq_api_key_here

# ========== DATABASE (Optional - if using PostgreSQL) ==========
DATABASE_URL=postgresql://user:password@localhost:5432/expense_tax_db

# ========== FRONTEND URLs (for CORS) ==========
# For Vercel Frontend: https://your-frontend.vercel.app
# For local development: http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# ========== NODE ENVIRONMENT ==========
# Set to 'production' for Render.com
# Set to 'development' for local testing
